NODE_ENV=production
PORT=3001

# Database — use DATABASE_URL (Railway provides this) OR individual vars
DATABASE_URL=postgresql://user:password@host:5432/dbname
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=ecommerce

# Redis — use REDIS_URL (Railway provides this) OR individual vars
REDIS_URL=redis://default:password@host:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Public API URL (used to build image URLs when STORAGE_TYPE=local)
API_URL=https://your-api.railway.app

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# Storage: "local" (default, dev only) or "s3" (production)
STORAGE_TYPE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=your-bucket-name
# S3_ENDPOINT=https://...  # only for Cloudflare R2 or other S3-compatible
